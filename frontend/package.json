{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:jest": "jest",
    "test:jest:ci": "jest --ci --passWithNoTests",
    "lint": "ng lint",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "betterer": "betterer",
    "betterer:update": "betterer --update"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "overrides": {
    "chokidar": "5.0.0",
    "readdirp": "5.0.0"
  },
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/entity": "^20.0.0",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "autoprefixer": "^10.5.0",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.24",
    "@angular/cli": "^20.3.24",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.0",
    "@betterer/angular": "^5.4.0",
    "@betterer/betterer": "^5.4.0",
    "@betterer/cli": "^5.4.0",
    "@types/jest": "^29.5.14",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.4.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-scss": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4",
    "vitest": "^3.1.1"
  }
}
